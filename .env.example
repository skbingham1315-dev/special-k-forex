ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# Forex ETF watchlist
# FXE=Euro, FXB=Pound, FXY=Yen, FXC=CAD, FXA=AUD, UUP=US Dollar
SYMBOLS=FXE,FXB,FXY,FXC,FXA,UUP

# Risk settings
MAX_POSITIONS=3
MAX_PORTFOLIO_EXPOSURE_PCT=60
MAX_POSITION_PCT=20
RISK_PER_TRADE_PCT=1
DAILY_KILL_SWITCH_PCT=3

# Minimum buying power before pausing new entries.
# When cash drops below this, the bot waits for positions to close before trading again.
MIN_BUYING_POWER=500

# Bracket order ATR multipliers
# Forex ETFs move slowly — tighter stops and targets than equities
STOP_ATR_MULTIPLIER=1.2
TAKE_PROFIT_ATR_MULTIPLIER=2.5

# Liquidity floor (forex ETFs have lower dollar volume than SPY/QQQ)
MIN_AVG_DOLLAR_VOLUME=5000000

# Logging
LOG_LEVEL=INFO
